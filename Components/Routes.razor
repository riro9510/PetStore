@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization

<!-- This file controls page routing for the app -->
<Router AppAssembly="@typeof(Program).Assembly">

    <!-- Runs when the route exists -->
    <Found Context="routeData">

        <!-- Shows the page and also checks authorization rules like [Authorize] -->
        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">

            <!-- Shows this message if the page exists but the user is not allowed to access it -->
            <NotAuthorized>
                <LayoutView Layout="@typeof(Layout.MainLayout)">
                    <div class="access-denied">
                        <h1>Access Denied</h1>
                        <p>You do not have access to this page.</p>
                        <a href="/">Return to Home</a>
                    </div>
                </LayoutView>
            </NotAuthorized>

        </AuthorizeRouteView>

        <!-- Moves focus to the first h1 after navigation for accessibility -->
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>

    <!-- Shows this when no matching page route is found -->
    <NotFound>
        <LayoutView Layout="@typeof(Layout.MainLayout)">
            <h1>Not Found</h1>
            <p>Sorry, the content you are looking for does not exist.</p>
        </LayoutView>
    </NotFound>

</Router>