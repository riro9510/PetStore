@using PetStore.Services
@using PetStore.Models
@inject PetService PetService

<nav class="nav-menu">

    <NavLink href="/" Match="NavLinkMatch.All">
        Home
    </NavLink>

    <div class="pets-menu">
        <span>Pets</span>

        <div class="pets-list">
            @foreach (var category in categories)
            {
                <NavLink href="@($"/petdisplay/{GetCategoryRoute(category)}")">
                    @FormatCategoryName(category.Name)
                </NavLink>
            }
        </div>
    </div>

    <NavLink href="/about">
        About Us
    </NavLink>

    <AuthorizeView Roles="Admin">
        <Authorized>
            <NavLink href="/management">
                Update Animals
            </NavLink>
        </Authorized>
    </AuthorizeView>

</nav>

@code {

    private List<PetCategory> categories = new();

    protected override void OnInitialized()
    {
        categories = PetService.GetAllCategories();
    }

    private string FormatCategoryName(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "";

        return char.ToUpper(name[0]) + name.Substring(1).ToLower();
    }

    private string GetCategoryRoute(PetCategory category)
    {
        if (!string.IsNullOrWhiteSpace(category.Route))
            return category.Route;

        return category.Name.ToLower();
    }
}