@using System.Security.Claims
@inherits LayoutComponentBase

<div class="page">
  <main>
    @* Header *@
    <header class="top-row">
      <div class="container-centered d-flex align-items-center justify-content-between">
        @* Brand *@
        <div class="me-auto">
          <a href="/" class="brand-link">
            <img src="images/logo-pawsitive-friends.svg" alt="Pawsitive Friends" height="48" width="48" />
            <span class="brand-text d-none d-md-flex">
              <span class="line-1">Pawsitive</span>
              <span class="line-2">Friends</span>
            </span>
          </a>
        </div>

        <button class="menu-trigger d-lg-none" style="z-index: 1100;" @onclick="ToggleMenu"
                aria-label="Toggle navigation">
          <i class="bi @(isMenuExpanded ? "bi-x-lg" : "bi-list")"></i>
        </button>

        @* Nav *@
        <nav class="nav-list @(isMenuExpanded ? "expanded" : "collapsed")">
          <NavLink class="nav-link" href="about" @onclick="CloseMenu">About Us</NavLink>
          <NavLink class="nav-link" href="pets" @onclick="CloseMenu">Adopt</NavLink>
          <NavLink class="nav-link" href="shelters" @onclick="CloseMenu">Shelters</NavLink>
          <NavLink class="nav-link" href="contact" @onclick="CloseMenu">Contact Us</NavLink>
          <NavLink class="nav-link" href="donate" @onclick="CloseMenu">Donate</NavLink>
        </nav>

        @* Auth *@
        <div class="ms-4">
          <AuthorizeView>
            <Authorized>
              @{
                var firstName = context.User.FindFirst(ClaimTypes.GivenName)?.Value
                                ?? context.User.Identity?.Name
                                ?? "User";
              }
              <span class="user-greeting me-2">
                Hello, <NavLink class="nav-link" href="management"><strong>@firstName</strong></NavLink>
              </span>
              <a class="btn btn-outline-danger btn-sm" href="/logout">Log Out</a>
            </Authorized>
            <NotAuthorized>
              <a class="signin-link btn btn-outline-primary" href="/signin">Sign In</a>
            </NotAuthorized>
          </AuthorizeView>
        </div>
      </div>
    </header>

    @* APP *@
    <article class="content px-4">
      @Body
    </article>
  </main>

  @* Footer *@
  <footer class="site-footer">
    <span>&copy; 2026 Pawsitive Friends</span>
    <NavLink href="/user-guide">User Guide</NavLink>
  </footer>
</div>

@code {
  private bool isMenuExpanded = false;

  private void ToggleMenu() => isMenuExpanded = !isMenuExpanded;
    
  private void CloseMenu() => isMenuExpanded = false;
}