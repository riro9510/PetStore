@page "/pets"
@rendermode InteractiveServer

@using Microsoft.VisualBasic
@using PetStore.Models
@using PetStore.Services
@inject PetService PetService
@inject NavigationManager NavManager
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Pets</PageTitle>

<!-- This page is for viewing pets in the system -->
<h1>@PageTitleText</h1>

<!-- Filter links for viewing pets by category -->
<div class="pet-filters">
  <a href="/pets">All</a>

  @foreach (var t in availableTypes)
  {
    <a href="/pets?type=@t">
      @mayus(t)
    </a>
  }
</div>

<div class="pets-container">

  @if (filteredPets.Count == 0)
  {
    <!-- Display message if no pets match the filter -->
    <p>No pets found in this category.</p>
  }
  else
  {
    <div class="pets-grid">

      @foreach (var pet in filteredPets)
      {
        <!-- Pass pet data and event handler to PetCard -->
        <PetCard Pet="pet" OnAboutMeClicked="OpenPetModal" />
      }
    </div>
  }
</div>

@if (selectedPet is not null)
{
  <!-- Dark background behind modal -->
  <div class="modal-backdrop-custom" @onclick="ClosePetModal"></div>

  <!-- Modal showing full pet information -->
  <div class="pet-modal">
    <div class="pet-modal-content">

      <!-- Close button for the modal -->
      <button class="modal-close-button" @onclick="ClosePetModal">×</button>

      <div class="pet-modal-image-container">
        <img src="@selectedPet.ImageUrl" alt="@selectedPet.Name image" />
      </div>

      <h2>@selectedPet.Name</h2>

      @{
        // Calculate pet age from year of birth
        int age = DateTime.Now.Year - selectedPet.YearOfBirth;
      }

      <p>
        <strong>Age: </strong>
        @if (age < 1)
        {
          <span>Less than a year old</span>
        }
        else
        {
          <span>@age @(age == 1 ? "year" : "years") old</span>
        }
      </p>

      <p><strong>Breed: </strong>@selectedPet.Breed</p>

      <p>
        <strong>Energy: </strong>
        @for (int i = 1; i <= 5; i++)
        {
          if (i <= selectedPet.Energy)
          {
            <!-- Highlight filled energy levels -->
            <span style="color: #FFD700;">⚡</span>
          }
          else
          {
            <!-- Dim remaining energy levels -->
            <span style="color: #ccc; opacity: 0.2;">⚡</span>
          }
        }
      </p>

      <p><strong>Description: </strong>@selectedPet.Description</p>

      <!-- Application button with pet name and shelter -->
      <button class="apply-button" @onclick="() => HandleApplyClick(selectedPet.Id)">
        Help @selectedPet.Name
      </button>
    </div>
  </div>
}

@code {
  // Query parameter from URL
  [Parameter]
  [SupplyParameterFromQuery(Name = "type")]
  public string? type { get; set; }

  // List of pets to display after filtering
  private List<Pet> filteredPets = new();

  // Unique list of available pet types for filter links
  private List<string> availableTypes = new();

  // Stores the selected pet for the modal
  private Pet? selectedPet;

  // Dynamically updates page title based on selected filter
  private string PageTitleText =>
      string.IsNullOrWhiteSpace(type)
          ? "Pets"
          : mayus(type);

  // Capitalizes the first letter of a string for display purposes.
  string mayus(string text)
  {
    if (string.IsNullOrEmpty(text)) return text;
    return char.ToUpper(text[0]) + text.Substring(1);
  }

  // Opens the modal for the selected pet
  void OpenPetModal(Pet pet)
  {
    selectedPet = pet;
  }

  // Closes the modal
  void ClosePetModal()
  {
    selectedPet = null;
  }

  protected override void OnParametersSet()
  {
    // Get all unique pet types for filtering
    availableTypes = PetService.GetAllPets()
        .Select(p => p.Type)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(t => t)
        .ToList();

    // Apply filter based on query parameter
    if (string.IsNullOrWhiteSpace(type))
    {
      filteredPets = PetService.GetAllPets();
    }
    else
    {
      filteredPets = PetService.GetPetsByCategory(type);
    }
  }

  // Handler to ensure visitor signs in before seeing the application
  private async Task HandleApplyClick(string petId)
  {
    var authState = await AuthStateProvider.GetAuthenticationStateAsync();
    var user = authState.User;

    // Build the page we want to return to after sign in
    var returnUrl = Uri.EscapeDataString($"/application?petId={petId}");

    // If user is not signed in, send them to sign in page
    if (user.Identity?.IsAuthenticated != true)
    {
      NavManager.NavigateTo($"/signin?returnUrl={returnUrl}", forceLoad: true);
    }
    else
    {
      // If already signed in, go straight to the application page
      NavManager.NavigateTo($"/application?petId={petId}", forceLoad: true);
    }
  }
}