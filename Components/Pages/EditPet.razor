@page "/management/edit/{id}"
@rendermode InteractiveServer
@attribute [Authorize(Roles = Roles.Admin)]

@using PetStore.Models
@using PetStore.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Authorization
@using System.IO

@inject PetService PetService
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Env

<PageTitle>Management | Edit Pets</PageTitle>

<!-- This page is for editing pets already in the system -->
<h1>Edit Pet</h1>

@if (editPet is null)
{
  <p>Pet not found.</p>
}
else
{
  <EditForm Model="editPet" OnValidSubmit="SavePet">
    <DataAnnotationsValidator />

    <div>
      <label>Name:</label>
      <InputText class="form-control" @bind-Value="editPet.Name" />
      <ValidationMessage For="@(() => editPet.Name)" />
    </div>

    <div>
      <label>Type:</label>
      <InputSelect class="form-control" @bind-Value="editPet.Type">
        <option value="">Select a Type</option>
        @foreach (var category in categories)
        {
          <option value="@category.Name">@category.Name</option>
        }
      </InputSelect>
      <ValidationMessage For="@(() => editPet.Type)" />
    </div>

    <div>
      <label>Breed:</label>
      <InputText class="form-control" @bind-Value="editPet.Breed" />
      <ValidationMessage For="@(() => editPet.Breed)" />
    </div>

    <div>
      <label>Year of Birth:</label>
      <InputNumber class="form-control" @bind-Value="editPet.YearOfBirth" />
      <ValidationMessage For="@(() => editPet.YearOfBirth)" />
    </div>

    <div>
      <label>Description:</label>
      <InputTextArea class="form-control" @bind-Value="editPet.Description" />
    </div>

    <div>
      <label>Image URL:</label>
      <InputText class="form-control" @bind-Value="editPet.ImageUrl" />
    </div>

    <div class="mb-3">
      <label class="form-label">OR <br/> Upload New Image</label>
      <InputFile class="form-control" OnChange="HandleFileSelected" accept="image/*" />

      @if (!string.IsNullOrWhiteSpace(uploadMessage))
      {
        <p class="mt-2">@uploadMessage</p>
      }
    </div>

    <!-- Energy picker will allow admin to hover to see energy amount, and click to set it -->
    <div class="mb-3">
      <label class="form-label">Energy Level</label>

      <div class="energy-picker" @onmouseleave="ClearEnergyHover">
        @for (int i = 1; i <= 5; i++)
        {
          var level = i;
          <span class="energy-icon @(GetEnergyClass(level, editPet!.Energy, hoverEnergy))" @onclick="() => SetEnergy(level)"
                @onmouseenter="() => PreviewEnergy(level)">
            ⚡
          </span>
        }
      </div>

      <ValidationMessage For="@(() => editPet!.Energy)" />
    </div>

    <div>
      <label>Shelter:</label>
      <InputSelect class="form-control" @bind-Value="editPet.Shelter_id">
        <option value="">Select a Shelter</option>
        @foreach (var shelter in shelters)
        {
          <option value="@shelter.Id">@shelter.Name</option>
        }
      </InputSelect>
      <ValidationMessage For="@(() => editPet.Shelter_id)" />
    </div>

    <div class="form-check">
      <InputCheckbox class="form-check-input" @bind-Value="editPet.Is_Friendly" />
      <label class="form-check-label">Friendly</label>
    </div>

    <div class="form-check">
      <InputCheckbox class="form-check-input" @bind-Value="editPet.Is_Adopt" />
      <label class="form-check-label">Available for Adoption</label>
    </div>

    <div class="form-check">
      <InputCheckbox class="form-check-input" @bind-Value="editPet.Is_Foster" />
      <label class="form-check-label">Available for Foster</label>
    </div>

    <br />

    <button type="submit">Save Changes</button>
    <button type="button" @onclick="Cancel">Cancel</button>
  </EditForm>
}

@code {
  [Parameter]
  public required string Id { get; set; }

  private Pet? editPet { get; set; }
  private List<PetCategory> categories = new();

  private List<Shelter> shelters = new();

  private IBrowserFile? selectedFile;
  private string uploadMessage = "";

  protected override void OnInitialized()
  {
    categories = PetService.GetAllCategories();
    shelters = PetService.GetAllShelters();

    var pet = PetService.GetPetById(Id);

    if (pet is not null)
    {
      editPet = new Pet
      {
        Id = pet.Id,
        Name = pet.Name,
        Type = pet.Type,
        Breed = pet.Breed,
        YearOfBirth = pet.YearOfBirth,
        Description = pet.Description,
        ImageUrl = pet.ImageUrl,
        Energy = pet.Energy,
        Shelter_id = pet.Shelter_id,
        Is_Friendly = pet.Is_Friendly,
        Is_Adopt = pet.Is_Adopt,
        Is_Foster = pet.Is_Foster
      };
    }
  }

  private void HandleFileSelected(InputFileChangeEventArgs e)
  {
    selectedFile = e.File;

    uploadMessage = selectedFile is not null
      ? $"Selected file: {selectedFile.Name}"
      : "";
  }

  // ENERGY LOGIC
  private int? hoverEnergy;

  private void SetEnergy(int level)
  {
    if (editPet is not null)
      editPet.Energy = level;
  }

  private void PreviewEnergy(int level)
  {
    hoverEnergy = level;
  }

  private void ClearEnergyHover()
  {
    hoverEnergy = null;
  }

  private string GetEnergyClass(int iconLevel, int selectedEnergy, int? hoverLevel)
  {
    var activeLevel = hoverLevel ?? selectedEnergy;
    return iconLevel <= activeLevel ? "filled" : "empty";
  }

  private async Task SavePet()
  {
    if (editPet is null) return;

    if (selectedFile is not null)
    {
      var uploadsFolder = Path.Combine(Env.WebRootPath, "images", "pets");

      if (!Directory.Exists(uploadsFolder))
        Directory.CreateDirectory(uploadsFolder);

      var extension = Path.GetExtension(selectedFile.Name);
      var fileName = $"{Guid.NewGuid()}{extension}";
      var filePath = Path.Combine(uploadsFolder, fileName);

      await using FileStream fs = new(filePath, FileMode.Create);
      await selectedFile.OpenReadStream(5 * 1024 * 1024).CopyToAsync(fs);

      editPet.ImageUrl = $"/images/pets/{fileName}";
    }
    else if (string.IsNullOrWhiteSpace(editPet.ImageUrl))
    {
      editPet.ImageUrl = "https://raw.githubusercontent.com/vsyang/pet-images/main/unavailable.jpg";
    }

    PetService.UpdatePet(editPet);
    NavigationManager.NavigateTo("/management");
  }

  private void Cancel()
  {
    NavigationManager.NavigateTo("/management");
  }
}