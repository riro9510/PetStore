@page "/management/edit/{id:int}"
@rendermode InteractiveServer

@using PetStore.Models
@using PetStore.Services
@using Microsoft.AspNetCore.Components.Forms
@inject PetService PetService
@inject NavigationManager NavigationManager

<h1>Edit Pet</h1>

@if (editPet is null)
{
  <p>Pet not found.</p>
}
else
{
  <EditForm Model="editPet" OnValidSubmit="SavePet" FormName="EditPetForm">
    <DataAnnotationsValidator />


    <div>
      <label>Name:</label>
      <InputText class="form-control" @bind-Value="editPet.Name" />
      <ValidationMessage For="@(() => editPet.Name)" />
    </div>

    <div>
      <label>Category:</label>
      <InputSelect class="form-control" @bind-Value="editPet.Category">
        <option value="">Select a category</option>
        @foreach (var category in categories)
        {
          <option value="@category.Name">@category.Name</option>
        }
      </InputSelect>
      <ValidationMessage For="@(() => editPet.Category)" />
    </div>

    <div>
      <label>Breed:</label>
      <InputText class="form-control" @bind-Value="editPet.Breed" />
      <ValidationMessage For="@(() => editPet.Breed)" />
    </div>

    <div>
      <label>Age:</label>
      <InputNumber class="form-control" @bind-Value="editPet.Age" />
      <ValidationMessage For="@(() => editPet.Age)" />
    </div>

    <div>
      <label>Description:</label>
      <InputText @bind-Value="editPet.Description" />
    </div>

    <div>
      <label>Image URL:</label>
      <InputText @bind-Value="editPet.ImageUrl" />
    </div>

    <button type="submit">Save Changes</button>
    <button type="button" @onclick="Cancel">Cancel</button>
  </EditForm>
}

@code {
  [Parameter]
  public int Id { get; set; }

  [SupplyParameterFromForm]
  private Pet? editPet { get; set; }

  private List<PetCategory> categories = new();

  protected override void OnInitialized()
  {
    categories = PetService.GetAllCategories();

    var pet = PetService.GetPetById(Id);

    if (pet is not null)
    {
      editPet = new Pet
      {
        Id = pet.Id,
        Name = pet.Name,
        Category = pet.Category,
        Breed = pet.Breed,
        Age = pet.Age,
        Description = pet.Description,
        ImageUrl = pet.ImageUrl
      };
    }
  }

  private void SavePet()
  {
    if (editPet is not null)
    {
      PetService.UpdatePet(editPet);
      NavigationManager.NavigateTo("/management");
    }
  }

  private void Cancel()
  {
    NavigationManager.NavigateTo("/management");
  }
}