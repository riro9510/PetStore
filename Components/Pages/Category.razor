@page "/management/categories"
@rendermode InteractiveServer

@using PetStore.Models
@using PetStore.Services
@inject PetService PetService

<h1>Category Management</h1>

<EditForm Model="newCategory" OnValidSubmit="AddCategory">
  <DataAnnotationsValidator />

  <div class="mb-3">
    <label class="form-label">Name</label>
    <InputText class="form-control" @bind-Value="newCategory.Name" />
    <ValidationMessage class="text-danger" For="@(() => newCategory.Name)" />
  </div>

  <button type="submit" class="btn btn-primary">Add Category</button>
</EditForm>

<hr />

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
  <p class="text-danger">@errorMessage</p>
}

<h3>Current Categories</h3>

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th style="width:200px;">Actions</th>
    </tr>
  </thead>

  <tbody>
    @foreach (var category in categories)
    {
      <tr>
        @if (editCategory?.Id == category.Id)
        {
          <td>
            <InputText class="form-control" @bind-Value="editCategory.Name" />
          </td>

          <td>
            <button class="btn btn-success me-2" @onclick="SaveEdit">
              Save
            </button>

            <button class="btn btn-secondary" @onclick="CancelEdit">
              Cancel
            </button>
          </td>
        }
        else
        {
          <td>@FormatCategoryName(category.Name)</td>

          <td>
            <button class="btn btn-warning me-2" @onclick="() => StartEdit(category)">
              Edit
            </button>

            <button class="btn btn-danger" @onclick="() => DeleteCategory(category.Id)">
              Delete
            </button>
          </td>
        }
      </tr>
    }
  </tbody>
</table>

@code {

  private PetCategory newCategory = new();
  private PetCategory? editCategory;

  private List<PetCategory> categories = new();
  private string errorMessage = "";

  protected override void OnInitialized()
  {
    LoadCategories();
  }

  private void LoadCategories()
  {
    categories = PetService.GetAllCategories();
  }

  private void AddCategory()
  {
    errorMessage = "";

    newCategory.Name = newCategory.Name.Trim().ToLower();

    PetService.AddCategory(newCategory);

    newCategory = new();
    LoadCategories();
  }

  private void StartEdit(PetCategory category)
  {
    errorMessage = "";

    editCategory = new PetCategory
    {
      Id = category.Id,
      Name = category.Name,
      Description = category.Description,
      Icon = category.Icon,
      Route = category.Route
    };
  }

  private void SaveEdit()
  {
    if (editCategory == null) return;

    errorMessage = "";

    editCategory.Name = editCategory.Name.Trim().ToLower();

    PetService.UpdateCategory(editCategory);

    editCategory = null;

    LoadCategories();
  }

  private void CancelEdit()
  {
    editCategory = null;
    errorMessage = "";
  }

  private void DeleteCategory(int id)
  {
    bool deleted = PetService.DeleteCategory(id);

    if (!deleted)
    {
      errorMessage = "Cannot delete this category because pets are still using it.";
    }
    else
    {
      errorMessage = "";
      LoadCategories();
    }
  }

  private string FormatCategoryName(string name)
  {
    if (string.IsNullOrWhiteSpace(name))
      return "";

    return char.ToUpper(name[0]) + name.Substring(1).ToLower();
  }
}