@page "/shelters/{id}"
@rendermode InteractiveServer

@using PetStore
@using PetStore.Models
@using PetStore.Services
@using Microsoft.AspNetCore.Components.Authorization

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject PetService PetService
@inject NavigationManager Navigation

<PageTitle>@(selectedShelter?.Name ?? "Shelter Details") - Pawsitive Friends</PageTitle>

@if (selectedShelter is null)
{
  <div class="container mt-5 text-center">
    <div class="alert alert-warning shadow-sm">
      <i class="bi bi-exclamation-triangle"></i> Shelter not found.
    </div>
    <a href="/shelters" class="btn btn-primary mt-3">Back to Shelters</a>
  </div>
}
else
{
  <section class="shelter-page">
    @* Hero Section con Video Background *@
    <div class="shelter-hero">
      <div class="video-overlay"></div>
      <video autoplay muted loop playsinline class="hero-video">
        <source src="videos/shelters-hero-presentation.mp4" type="video/mp4">
        Your browser does not support the video tag.
      </video>

      <div class="hero-content">
        <div class="container">
          <span class="badge bg-accent text-dark mb-2">Verified Shelter</span>
          <h1 class="display-3 fw-bold">@selectedShelter.Name</h1>
          <p class="lead">Connecting hearts, one adoption at a time.</p>
        </div>
      </div>
    </div>

    <div class="container mt-n5 position-relative">
      <div class="row">
        @* Sidebar: Información del Refugio *@
        <div class="col-lg-4">
          <div class="info-card shadow-lg p-4 rounded-4 mb-4">
            <h3 class="h5 fw-bold text-primary mb-3">Contact Information</h3>
            <hr />
            <div class="d-flex mb-3">
              <i class="bi bi-geo-alt-fill text-secondary me-3"></i>
              <div>
                <p class="mb-0 fw-bold">Location</p>
                <p class="text-muted small mb-0">@selectedShelter.City, @selectedShelter.State. @selectedShelter.Country
                </p>
              </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(selectedShelter.Email))
            {
              <div class="d-flex mb-3">
                <i class="bi bi-envelope-fill text-secondary me-3"></i>
                <a href="mailto:@selectedShelter.Email"
                   class="text-decoration-none small text-dark">@selectedShelter.Email</a>
              </div>
            }

            @if (!string.IsNullOrWhiteSpace(selectedShelter.Phone))
            {
              <div class="d-flex">
                <i class="bi bi-telephone-fill text-secondary me-3"></i>
                <a href="tel:@selectedShelter.Phone" class="text-decoration-none small text-dark">@selectedShelter.Phone</a>
              </div>
            }
          </div>
        </div>

        @* Main: Lista de Mascotas *@
        <div class="col-lg-8">
          <div class="pets-section p-4 bg-white rounded-4 shadow-sm">
            <h2 class="h4 fw-bold mb-4">Available Pets at this Shelter</h2>
                        
            @if (shelterPets.Count == 0)
            {
              <div class="text-center py-5">
                <i class="bi bi-emoji-frown fs-1 text-muted"></i>
                <p class="mt-2">No pets currently listed here.</p>
              </div>
            }
            else
            {
              <div class="row g-3">
                @foreach (var pet in shelterPets)
                {
                  <div class="col-md-6">
                    <PetCard Pet="pet" OnAboutMeClicked="OpenPetModal" />
                  </div>
                }
              </div>
            }
          </div>
        </div>
      </div>
    </div>
  </section>
}

@* Modal persistente con lógica de UI mejorada *@
@if (selectedPet is not null)
{
  <div class="modal-backdrop-custom show" @onclick="ClosePetModal"></div>
  <div class="pet-modal animate__animated animate__zoomIn">
    <div class="pet-modal-content rounded-4 border-0">
      <button class="modal-close-button" @onclick="ClosePetModal">×</button>
      <div class="pet-modal-image-container">
        <img src="@selectedPet.ImageUrl" alt="@selectedPet.Name" />
      </div>
      <div class="p-4">
        <h2 class="fw-bold text-primary">@selectedPet.Name</h2>
        <div class="d-flex gap-2 mb-3">
          <span class="badge bg-light text-dark">@selectedPet.Breed</span>
          <span class="badge bg-light text-dark">Age: @(DateTime.Now.Year - selectedPet.YearOfBirth)</span>
        </div>
        <p class="text-muted">@selectedPet.Description</p>
        <div class="energy-meter mt-3 p-2 bg-light rounded">
          <span class="small fw-bold">Energy Level:</span>
          @for (int i = 1; i <= 5; i++)
          {
            <span class="@(i <= selectedPet.Energy ? "text-warning" : "text-muted opacity-25")">⚡</span>
          }
        </div>
      </div>
    </div>
  </div>
}

@code {
  // Route parameter used to identify which shelter to display
  [Parameter]
  public required string id { get; set; }

  // Stores the selected shelter data
  private Shelter? selectedShelter;

  // Stores pets that belong to this shelter
  private List<Pet> shelterPets = new();

  // Stores the selected pet for the modal
  private Pet? selectedPet;

  // Runs whenever the page loads or parameter changes
  protected override void OnParametersSet()
  {
    // Get shelter using ID from URL
    selectedShelter = PetService.GetShelterById(id);

    if (selectedShelter is not null)
    {
      // Filter pets that match this shelter's ID
      shelterPets = PetService
          .GetAllPets()
          .Where(p => p.Shelter_id == selectedShelter.Id)
          .ToList();
    }
    else
    {
      // If shelter not found, clear pet list
      shelterPets = new List<Pet>();
    }
  }

  // Opens the modal for the selected pet
  void OpenPetModal(Pet pet)
  {
    selectedPet = pet;
  }

  // Closes the modal
  void ClosePetModal()
  {
    selectedPet = null;
  }
}