@page "/about"
@rendermode InteractiveServer

<PageTitle>About Us</PageTitle>

<h1>About Pawsitive Friends</h1>

<p class="about-text">
  We are a non-profit organization that has partnered with shelters worldwide to bring
  attention to animals in need of love, care, and a forever home. Our mission is to
  connect people with shelters and help shine a light on animals waiting for a second chance.
</p>

<div class="card-grid">
  @foreach (var shelter in shelters)
  {
    <div class="flip-card" @onclick="() => shelter.IsFlipped = !shelter.IsFlipped">
      <div class="flip-card-inner @(shelter.IsFlipped ? "flipped" : "")">
                
        <div class="flip-card-front">
          <h3>@shelter.Name</h3>
          <p>Click to view shelter info</p>
        </div>

        <div class="flip-card-back">
          <h3>@shelter.Name</h3>
          <p><strong>Animal Specialty:</strong> @shelter.Specialty</p>
          <p><strong>Location:</strong> @shelter.Location</p>
          <p><strong>Email:</strong> @shelter.Email</p>
        </div>

      </div>
    </div>
  }
</div>

