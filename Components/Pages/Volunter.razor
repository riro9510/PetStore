@page "/volunteer"
@rendermode InteractiveServer
@attribute [Authorize(Roles = $"{Roles.Client},{Roles.Admin}")]

@using PetStore.Data
@using PetStore.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Authorization

@inject PetStoreContext DbContext
@inject NavigationManager NavigationManager

<PageTitle>Volunteer - Pawsitive Friends</PageTitle>

<div class="container mt-4">
    <div class="row">
        @* Columna Izquierda: Formulario de Registro *@
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white p-3">
                    <h4 class="mb-0"><i class="bi bi-person-heart"></i> Join Our Team</h4>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-4">Would you like to help our pets? Please fill out the form below.</p>

                    <EditForm Model="volunteerApplication" OnValidSubmit="SubmitApplication" FormName="VolunteerForm">
                        <DataAnnotationsValidator />

                        <div class="mb-4">
                            <label class="form-label fw-bold">Volunteer Type</label>
                            <InputRadioGroup @bind-Value="volunteerApplication.VolunteerType">
                                <div class="btn-group w-100" role="group">
                                    <div class="form-check me-3">
                                        <InputRadio Value="@VolunteerType.PetWalker" class="form-check-input" id="walker" />
                                        <label class="form-check-label" for="walker">Pet Walker</label>
                                    </div>
                                    <div class="form-check me-3">
                                        <InputRadio Value="@VolunteerType.PetCare" class="form-check-input" id="care" />
                                        <label class="form-check-label" for="care">Pet Care</label>
                                    </div>
                                    <div class="form-check">
                                        <InputRadio Value="@VolunteerType.Institution" class="form-check-input" id="inst" />
                                        <label class="form-check-label" for="inst">Institution</label>
                                    </div>
                                </div>
                            </InputRadioGroup>
                            <ValidationMessage For="@(() => volunteerApplication.VolunteerType)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Full Name or Institution Name</label>
                            <InputText class="form-control" @bind-Value="volunteerApplication.Name" placeholder="Enter name" />
                            <ValidationMessage For="@(() => volunteerApplication.Name)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Contact Phone Number</label>
                            <InputText class="form-control" @bind-Value="volunteerApplication.PhoneNumber" placeholder="+1..." />
                            <ValidationMessage For="@(() => volunteerApplication.PhoneNumber)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Preferred Email</label>
                            <InputText class="form-control" @bind-Value="volunteerApplication.Email" placeholder="email@example.com" />
                            <ValidationMessage For="@(() => volunteerApplication.Email)" class="text-danger small" />
                        </div>

                        <button type="submit" class="btn btn-success w-100 py-2 fw-bold mt-2">
                            Submit Application
                        </button>
                    </EditForm>
                </div>
            </div>
        </div>

        @* Columna Derecha: Lista de Aplicaciones Recientes *@
        <div class="col-md-7">
            <h4 class="mb-3 text-secondary">Current Volunteer Applications</h4>
            
            @if (!volunteerApplications.Any())
            {
                <div class="text-center py-5 bg-light rounded shadow-sm">
                    <i class="bi bi-clipboard-x fs-1 text-muted"></i>
                    <p class="mt-2 text-muted">No applications received yet.</p>
                </div>
            }
            else
            {
                @foreach (var group in volunteerApplications.GroupBy(v => v.SubmittedAt.Date))
                {
                    <div class="mb-4">
                        <div class="d-flex align-items-center mb-2">
                            <span class="badge bg-secondary me-2">@group.Key.ToString("MMMM dd, yyyy")</span>
                            <hr class="flex-grow-1 my-0" />
                        </div>
                        
                        <div class="list-group shadow-sm">
                            @foreach (var app in group.OrderByDescending(v => v.SubmittedAt))
                            {
                                <div class="list-group-item list-group-item-action border-0 mb-1 rounded p-3">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1 text-primary fw-bold">@app.Name</h6>
                                        <small class="text-muted">@app.SubmittedAt.ToString("HH:mm")</small>
                                    </div>
                                    <div class="d-flex align-items-center text-muted mb-2">
                                        <span class="badge @GetBadgeClass(app.VolunteerType) me-2">@app.VolunteerType</span>
                                    </div>
                                    <div class="small">
                                        <span class="me-3"><i class="bi bi-telephone"></i> @app.PhoneNumber</span>
                                        <span><i class="bi bi-envelope"></i> @app.Email</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private VolunteerApplication volunteerApplication = new();
    private List<VolunteerApplication> volunteerApplications = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadApplications();
    }

    private async Task SubmitApplication()
    {
        volunteerApplication.SubmittedAt = DateTime.UtcNow; // Mejor práctica Senior: Siempre UTC en BD
        DbContext.VolunteerApplications.Add(volunteerApplication);
        await DbContext.SaveChangesAsync();
        
        volunteerApplication = new VolunteerApplication();
        await LoadApplications();
    }

    private async Task LoadApplications()
    {
        volunteerApplications = await DbContext.VolunteerApplications
            .AsNoTracking() // Tip Senior: Mejora rendimiento para lecturas
            .OrderByDescending(v => v.SubmittedAt)
            .ToListAsync();
    }

    private string GetBadgeClass(VolunteerType type) => type switch
    {
        VolunteerType.PetWalker => "bg-info text-dark",
        VolunteerType.PetCare => "bg-warning text-dark",
        VolunteerType.Institution => "bg-purple text-white", // Requiere definir color purple o usar otro
        _ => "bg-light text-dark"
    };
}