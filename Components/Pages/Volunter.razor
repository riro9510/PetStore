@page "/volunteer"
@rendermode InteractiveServer
@attribute [Authorize(Roles = $"{Roles.Client},{Roles.Admin}")]

@using PetStore.Data
@using PetStore.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Authorization

@inject PetStoreContext DbContext
@inject NavigationManager NavigationManager
@using Microsoft.EntityFrameworkCore

<PageTitle>Volunteer - Pawsitive Friends</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white p-3">
                    <h4 class="mb-0">
                        <i class="bi bi-person-heart"></i> Join Our Team
                    </h4>
                </div>

                <div class="card-body p-4">
                    <p class="text-muted mb-4">
                        Would you like to help our pets? Please fill out the form below.
                    </p>

                    <EditForm Model="volunteerApplication" OnValidSubmit="SubmitApplication" FormName="VolunteerForm">
                        <DataAnnotationsValidator />

                        <div class="mb-4">
                            <label class="form-label fw-bold">Volunteer Type</label>
                            <InputRadioGroup @bind-Value="volunteerApplication.VolunteerType">
                                <div class="btn-group w-100" role="group">
                                    <div class="form-check me-3">
                                        <InputRadio Value="@VolunteerType.PetWalker" class="form-check-input"
                                                    id="walker" />
                                        <label class="form-check-label" for="walker">Pet Walker</label>
                                    </div>

                                    <div class="form-check me-3">
                                        <InputRadio Value="@VolunteerType.PetCare" class="form-check-input" id="care" />
                                        <label class="form-check-label" for="care">Pet Care</label>
                                    </div>

                                    <div class="form-check">
                                        <InputRadio Value="@VolunteerType.Institution" class="form-check-input"
                                                    id="inst" />
                                        <label class="form-check-label" for="inst">Institution</label>
                                    </div>
                                </div>
                            </InputRadioGroup>
                            <ValidationMessage For="@(() => volunteerApplication.VolunteerType)"
                                               class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Full Name or Institution Name</label>
                            <InputText class="form-control" @bind-Value="volunteerApplication.Name"
                                       placeholder="Enter name" />
                            <ValidationMessage For="@(() => volunteerApplication.Name)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Contact Phone Number</label>
                            <InputText class="form-control" @bind-Value="volunteerApplication.PhoneNumber"
                                       placeholder="+1..." />
                            <ValidationMessage For="@(() => volunteerApplication.PhoneNumber)"
                                               class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Preferred Email</label>
                            <InputText class="form-control" @bind-Value="volunteerApplication.Email"
                                       placeholder="email@example.com" />
                            <ValidationMessage For="@(() => volunteerApplication.Email)" class="text-danger small" />
                        </div>

                        <button type="submit" class="btn btn-success w-100 py-2 fw-bold mt-2">
                            Submit Application
                        </button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // Holds the current form data entered by the user
    private VolunteerApplication volunteerApplication = new();

    // Handles form submission when all validation rules pass
    private async Task SubmitApplication()
    {
        // Save the submission time
        volunteerApplication.SubmittedAt = DateTime.Now;

        // Add the application to the database
        DbContext.VolunteerApplications.Add(volunteerApplication);

        // Save so the database generates the Id
        await DbContext.SaveChangesAsync();

        // Redirect to thank you page with this application's Id
        NavigationManager.NavigateTo($"/volunteer-thankyou?id={volunteerApplication.Id}");
    }
}