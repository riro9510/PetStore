@page "/donate"
@using PetStore.Models
@using PetStore.Services
@inject IDonationService DonationService
@inject NavigationManager NavManager

<PageTitle>Make a Donation - Pawsitive Friends</PageTitle>

<div class="container mt-4 mb-5">
    @* Impact *@
    <div class="row mb-5 align-items-center">
        <div class="col-lg-7">
            <h1 class="display-4 fw-bold text-primary mb-3">Every Donation Tells a Story</h1>
            <p class="lead text-dark mb-4">
                Your contribution goes directly to providing medical care, nutritious food, and 
                comfortable shelter for animals waiting for their forever homes. Thanks to people 
                like you, we can transform a life of neglect into one of joy and wagging tails.
            </p>
            <div class="alert shadow-sm border-0 bg-white p-4">
                <h5 class="text-secondary fw-bold"><i class="bi bi-heart-fill me-2"></i> Our Heartfelt Thanks</h5>
                <p class="mb-0 text-muted">
                    We are deeply grateful for each donor. Your generosity is the engine that keeps 
                    our shelters running and makes the dream of a better life a reality for hundreds 
                    of animals every year.
                </p>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="video-container shadow-lg rounded-4 overflow-hidden">
                <iframe width="100%" height="315" 
                        src="https://www.youtube.com/embed/WJ7_7vQIi3U" 
                        title="Impact Video" frameborder="0" 
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                        allowfullscreen></iframe>
            </div>
        </div>
    </div>

    <hr class="my-5 opacity-25" />

    <div class="row g-4">
        @* Form *@
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h3 class="card-title fw-bold text-primary mb-4">Support Our Pets</h3>

                    <EditForm Model="@donationModel" OnValidSubmit="HandleValidSubmit" FormName="DonationForm">
                        <DataAnnotationsValidator />
                        
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold small">First Name</label>
                                <InputText @bind-Value="donationModel!.FirstName" class="form-control form-control-lg shadow-sm" placeholder="John" />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold small">Last Name</label>
                                <InputText @bind-Value="donationModel!.LastName" class="form-control form-control-lg shadow-sm" placeholder="Doe" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold small">Amount (USD)</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-white border-end-0 text-success fw-bold">$</span>
                                <InputNumber @bind-Value="donationModel!.Amount" class="form-control border-start-0 shadow-sm" placeholder="25.00" />
                            </div>
                            <ValidationMessage For="@(() => donationModel!.Amount)" class="text-danger small mt-1" />
                        </div>

                        <div class="form-check form-switch mb-4">
                            <InputCheckbox id="isAnonymous" @bind-Value="donationModel!.IsAnonymous" class="form-check-input" />
                            <label class="form-check-label text-muted" for="isAnonymous">Make my donation anonymous</label>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 py-3 shadow fw-bold" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Complete My Donation
                        </button>
                    </EditForm>
                </div>
            </div>
        </div>

        @* Recents *@
        <div class="col-md-6">
            <DonationList />
        </div>
    </div>
</div>

<style>
    .video-container {
        position: relative;
        padding-bottom: 56.25%; 
        height: 0;
    }
    .video-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border-radius: 1rem;
    }
    .text-primary { color: var(--primary) !important; }
    .text-secondary { color: var(--secondary) !important; }
</style>

@code {
    [SupplyParameterFromForm(FormName = "DonationForm")]
    private Donation? donationModel { get; set; }
    private bool isLoading = false;

    protected override void OnInitialized() => donationModel ??= new();

    private async Task HandleValidSubmit()
    {
        if (donationModel is null) return;
        isLoading = true;
        try
        {
            var created = await DonationService.CreateDonationAsync(donationModel);
            NavManager.NavigateTo($"/donate/validate?donationId={created.Id}");
        }
        finally
        {
            isLoading = false;
        }
    }
}