@page "/management"

@using PetStore.Models
@using PetStore.Services
@using Microsoft.AspNetCore.Components.Forms
@inject PetService PetService

<h1>Pet Management</h1>

<h3>Add Pet</h3>

<EditForm Model="newPet" OnValidSubmit="AddPet" FormName="AddPetForm">
  <DataAnnotationsValidator />
  <ValidationSummary />

  <InputText @bind-Value="newPet.Name" placeholder="Name" />
  <InputText @bind-Value="newPet.Category" placeholder="Category" />
  <InputText @bind-Value="newPet.Breed" placeholder="Breed" />
  <InputNumber @bind-Value="newPet.Age" />
  <InputText @bind-Value="newPet.ImageUrl" placeholder="Image URL" />
  <InputText @bind-Value="newPet.Description" placeholder="Description" />

  <button type="submit">Add Pet</button>
</EditForm>

<hr />

<h3>All Pets</h3>

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Category</th>
      <th>Breed</th>
      <th>Age</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    @foreach (var pet in pets)
    {
      <tr>
        <td>@pet.Name</td>
        <td>@pet.Category</td>
        <td>@pet.Breed</td>
        <td>@pet.Age</td>
        <td>
          <button @onclick="() => DeletePet(pet.Id)">Delete</button>
        </td>
      </tr>
    }
  </tbody>
</table>

@code {
  private List<Pet> pets = new();

  [SupplyParameterFromForm]
  private Pet newPet { get; set; } = new();

  protected override void OnInitialized()
  {
    pets = PetService.GetAllPets();
  }

  private void AddPet()
  {
    PetService.AddPet(newPet);
    pets = PetService.GetAllPets();
    newPet = new Pet();
  }

  private void DeletePet(int id)
  {
    PetService.DeletePet(id);
    pets = PetService.GetAllPets();
  }
}