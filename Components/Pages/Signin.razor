@page "/signin"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>Sign In - Pawsitive Friends</PageTitle>

<div class="login-container d-flex align-items-center justify-content-center">
  <div class="login-card shadow-lg animate__animated animate__fadeIn">
    <div class="login-header text-center">
      @* Logo de marca para dar confianza *@
      <img src="images/logo-pawsitive-friends.svg" alt="Pawsitive Friends" height="80" class="mb-3" />
      <h2 class="fw-bold text-primary">Welcome Back</h2>
      <p class="text-muted">Join the pack and help your Pawsitive Friends!</p>
    </div>

    <div class="login-body p-4">
      <div class="d-grid gap-3">
        @* Botón de Google con estilo Institucional *@
        <a class="btn btn-google d-flex align-items-center justify-content-center py-3" href="@googleLoginUrl">
          <img src="https://authjs.dev/img/providers/google.svg" alt="Google" width="24" class="me-3" />
          <span>Continue with Google</span>
        </a>
                
        @* Separador visual *@
        <div class="divider d-flex align-items-center my-3">
          <hr class="flex-grow-1" />
          <span class="mx-3 text-muted small text-uppercase">Secure Access</span>
          <hr class="flex-grow-1" />
        </div>

        <p class="text-center small text-muted px-4">
          By signing in, you agree to our
          <a href="/terms" class="text-secondary text-decoration-none">Terms of Service</a>.
        </p>
      </div>
    </div>
        
    <div class="login-footer text-center p-3 bg-light rounded-bottom">
      <a href="/" class="text-primary text-decoration-none small">
        <i class="bi bi-arrow-left"></i> Back to Home
      </a>
    </div>
  </div>
</div>

@code {
  private string googleLoginUrl = "/login-google";

  protected override void OnInitialized()
  {
    var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
    var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

    if (query.TryGetValue("returnUrl", out var returnUrl) &&
        !string.IsNullOrWhiteSpace(returnUrl))
    {
      googleLoginUrl = $"/login-google?returnUrl={Uri.EscapeDataString(returnUrl.ToString())}";
    }
  }
}