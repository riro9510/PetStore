@page "/management/add"
@rendermode InteractiveServer
@attribute [Authorize(Roles = Roles.Admin)]

@using PetStore.Models
@using PetStore.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Authorization
@using System.IO

@inject PetService PetService
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Env

<PageTitle>Management | Add Pets</PageTitle>


<!-- This page is for adding new pets into the system -->
<h1>Add Pet</h1>

<EditForm Model="newPet" OnValidSubmit="SavePet">
  <DataAnnotationsValidator />

  <div class="mb-3">
    <label for="petName">Name:</label>
    <InputText id="petName" class="form-control" @bind-Value="newPet.Name" />
    <ValidationMessage For="@(() => newPet.Name)" />
  </div>

  <div class="mb-3">
    <label for="petType">Type:</label>
    <InputSelect id="petType" class="form-control" @bind-Value="newPet.Type">
      <option value="">Select a Type</option>
      @foreach (var type in categories)
      {
        <option value="@type.Name">@type.Name</option>
      }
    </InputSelect>
    <ValidationMessage For="@(() => newPet.Type)" />
  </div>

  <div class="mb-3">
    <label for="petBreed">Breed:</label>
    <InputText id="petBreed" class="form-control" @bind-Value="newPet.Breed" />
    <ValidationMessage For="@(() => newPet.Breed)" />
  </div>

  <div class="mb-3">
    <label for="petAge">Year of Birth:</label>
    <InputNumber id="petAge" class="form-control" @bind-Value="newPet.YearOfBirth" />
    <ValidationMessage For="@(() => newPet.YearOfBirth)" />
  </div>

  <div class="mb-3">
    <!-- Textarea for longer description input -->
    <label for="petDescription">Description:</label>
    <InputTextArea id="petDescription" class="form-control" @bind-Value="newPet.Description" />
  </div>

  <div class="mb-3">
    <!-- Default image link if user doesn't upload -->
    <label for="petImage">Image URL:</label>
    <InputText id="petImage" class="form-control" @bind-Value="newPet.ImageUrl" placeholder="Default used if empty" />
  </div>

  <div class="mb-3">
    <!-- Allows user to upload an image file from their computer -->
    <label for="petImageUpload">OR Upload Image:</label>
    <InputFile id="petImageUpload" class="form-control" OnChange="HandleFileSelected" accept="image/*" />

    @if (!string.IsNullOrWhiteSpace(uploadMessage))
    {
      <p class="mt-2">@uploadMessage</p>
    }
  </div>

  <!-- Energy picker will allow admin to hover over icon, and click to set the amount-->
  <div class="mb-3">
    <label class="form-label">Energy Level</label>

    <div class="energy-picker" @onmouseleave="ClearEnergyHover">
      @for (int i = 1; i <= 5; i++)
      {
        var level = i;
        <button type="button"
                class="energy-icon-button @(GetEnergyClass(level, newPet.Energy, hoverEnergy))"
                @onclick="() => SetEnergy(level)"
                @onmouseenter="() => PreviewEnergy(level)"
                aria-label="Set energy level to @level">
          ⚡
        </button>
      }
    </div>

    <ValidationMessage For="@(() => newPet.Energy)" />
  </div>

  <!-- Shelters presented as dropdown menu to avoid confusion with different shelters -->
  <div class="mb-3">
    <label for="shelter">Shelter:</label>
    <InputSelect id="shelter" class="form-control" @bind-Value="newPet.Shelter_id">
      <option value="">Select a Shelter</option>
      @foreach (var shelter in shelters)
      {
        <option value="@shelter.Id">@shelter.Name</option>
      }
    </InputSelect>
    <ValidationMessage For="@(() => newPet.Shelter_id)" />
  </div>

  <div class="form-check accessible-check">
    <!-- Allows admin to let client know if pet is friendly or not -->
    <InputCheckbox id="friendly" class="form-check-input" @bind-Value="newPet.Is_Friendly" />
    <label for="friendly" class="form-check-label">Friendly</label>
  </div>
  <ValidationMessage For="@(() => newPet.Is_Friendly)" />


  <div class="form-check accessible-check">
    <!-- Admin lets client know if pet is available to adopt -->
    <InputCheckbox id="adoptable" class="form-check-input" @bind-Value="newPet.Is_Adopt" />
    <label for="adoptable" class="form-check-label">Available for Adoption:</label>
  </div>
  <ValidationMessage For="@(() => newPet.Is_Adopt)" />

  <div class="form-check accessible-check">
    <!-- Admin lets client know if pet is ready to foster -->
    <InputCheckbox id="fosterable" class="form-check-input" @bind-Value="newPet.Is_Foster" />
    <label for="fosterable" class="form-check-label">Available for Foster:</label>
  </div>
  <ValidationMessage For="@(() => newPet.Is_Foster)" />

  <div class="mt-3">
    <button type="submit" class="btn btn-primary me-2">Save</button>
    <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
  </div>
</EditForm>

@code {
  @* // Model bound to the form inputs
  [SupplyParameterFromForm] *@
  private Pet newPet { get; set; } = new();

  // List of pet categories loaded from the service
  private List<PetCategory> categories = new();

  // List of shelters loaded from service
  private List<Shelter> shelters = new();

  // Holds the uploaded file temporarily
  private IBrowserFile? selectedFile;

  // Message shown after selecting a file
  private string uploadMessage = "";

  // Load all categories and shelters when the page initializes
  protected override void OnInitialized()
  {
    categories = PetService.GetAllCategories();
    shelters = PetService.GetAllShelters();
  }

  // Handles file selection from the InputFile component.  Stores the file for later processing.
  private void HandleFileSelected(InputFileChangeEventArgs e)
  {
    selectedFile = e.File;

    uploadMessage = selectedFile is not null
      ? $"Selected file: {selectedFile.Name}"
      : "";
  }

  // Energy settings so admin can adjust energy level for pet
  private int? hoverEnergy;

  private void SetEnergy(int level)
  {
    newPet.Energy = level;
  }

  private void PreviewEnergy(int level)
  {
    hoverEnergy = level;
  }

  private void ClearEnergyHover()
  {
    hoverEnergy = null;
  }

  private string GetEnergyClass(int iconLevel, int selectedEnergy, int? hoverLevel)
  {
    var activeLevel = hoverLevel ?? selectedEnergy;
    return iconLevel <= activeLevel ? "filled" : "empty";
  }

  // Saves the pet to the database. If an image is uploaded, it is stored in wwwroot and linked. Otherwise, a default image is used.
  private async Task SavePet()
  {
    if (selectedFile is not null)
    {
      // Create folder path inside wwwroot for storing images
      var uploadsFolder = Path.Combine(Env.WebRootPath, "images", "pets");

      if (!Directory.Exists(uploadsFolder))
      {
        Directory.CreateDirectory(uploadsFolder);
      }

      // Generate unique file name to avoid overwriting
      var extension = Path.GetExtension(selectedFile.Name);
      var fileName = $"{Guid.NewGuid()}{extension}";
      var filePath = Path.Combine(uploadsFolder, fileName);

      // Save file with size limit (5 MB)
      await using FileStream fs = new(filePath, FileMode.Create);
      await selectedFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).CopyToAsync(fs);

      // Store relative path so the image can be displayed in the app
      newPet.ImageUrl = $"/images/pets/{fileName}";
    }
    else if (string.IsNullOrWhiteSpace(newPet.ImageUrl))
    {
      // Fallback image if no upload or URL is provided
      newPet.ImageUrl = "https://raw.githubusercontent.com/vsyang/pet-images/main/unavailable.jpg";
    }

    // Save pet using service
    PetService.AddPet(newPet);

    // Redirect back to management page
    NavigationManager.NavigateTo("/management");
  }

  // Cancels the operation and returns to management page.
  private void Cancel()
  {
    NavigationManager.NavigateTo("/management");
  }
}