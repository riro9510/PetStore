@page "/"
@inject NavigationManager NavManager

<PageTitle>Home | PetStore</PageTitle>

<div class="hero-section">
    <h1>Search to find your new best friend.</h1>
    <p>Find your new best friend today.</p>
    
    <ShelterSelector OnShelterSelected="HandleShelterSelection" />
</div>

@if (!string.IsNullOrEmpty(selectedShelterId))
{
    <div class="results-area">
        <p>Showing pets for shelter ID: <strong>@selectedShelterId</strong></p>
    </div>
}

@code {
    private string selectedShelterId = string.Empty;

    private void HandleShelterSelection(string id)
    {
        selectedShelterId = id;
        
        if (!string.IsNullOrEmpty(id))
        {
            // NavManager.NavigateTo($"/shelters/{id}");
        }
    }
}