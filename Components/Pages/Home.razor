@page "/"
@using PetStore.Services
@using PetStore.Models
@inject PetService PetService

<PageTitle>Pawsitive Friends</PageTitle>

<section class="home-hero">
  <h1>Welcome to Pawsitive Friends</h1>
  <p>
    Browse animals by category and find a pet you would love to adopt, foster, or sponsor.
  </p>
</section>

<section class="home-categories">
  <h2>Choose A Category</h2>

  <div class="category-grid">
    @foreach (var category in petCategories)
    {
      <NavLink class="category-card" href="@($"/petdisplay/{GetCategoryRoute(category)}")">
        <div class="category-icon">@category.Icon</div>
        <h3>@(char.ToUpper(category.Name[0]) + category.Name.Substring(1))</h3>
        <p>@category.Description</p>
      </NavLink>
    }
  </div>
</section>

@code {

  private List<PetCategory> petCategories = new();

  protected override void OnInitialized()
  {
    petCategories = PetService.GetAllCategories();
  }

  private string GetCategoryRoute(PetCategory category)
  {
    if (!string.IsNullOrWhiteSpace(category.Route))
      return category.Route;

    return category.Name.ToLower();
  }

  private string FormatName(string name)
  {
    if (string.IsNullOrWhiteSpace(name))
      return "";

    return char.ToUpper(name[0]) + name.Substring(1).ToLower();
  }
}