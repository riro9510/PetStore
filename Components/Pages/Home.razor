@page "/"

<PageTitle>Home</PageTitle>

<section class="home-hero">
  <h1>Welcome to PetStore</h1>
  <p>
    Browse animals by category and find a pet you would love to adopt, foster, or sponsor.
  </p>
</section>

<section class="home-categories">
  <h2>Choose a pet type</h2>

  <div class="category-grid">
    <a class="category-card" href="/dogs">
      <div class="category-icon">🐶</div>
      <h3>Dogs</h3>
      <p>Friendly, loyal, and ready for a home.</p>
    </a>

    <a class="category-card" href="/cats">
      <div class="category-icon">🐱</div>
      <h3>Cats</h3>
      <p>Curious, calm, and full of personality.</p>
    </a>

    <a class="category-card" href="/dragons">
      <div class="category-icon">🐉</div>
      <h3>Dragons</h3>
      <p>Magical companions with fiery charm.</p>
    </a>

    <a class="category-card" href="/unicorns">
      <div class="category-icon">🦄</div>
      <h3>Unicorns</h3>
      <p>Rare, graceful, and full of wonder.</p>
    </a>

    <a class="category-card" href="/birds">
      <div class="category-icon">🐦</div>
      <h3>Birds</h3>
      <p>Bright, social, and fun to watch.</p>
    </a>

    <a class="category-card" href="/elephants">
      <div class="category-icon">🐘</div>
      <h3>Elephants</h3>
      <p>Gentle giants with big hearts.</p>
    </a>
  </div>
</section>