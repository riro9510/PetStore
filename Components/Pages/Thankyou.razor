@page "/thankyou/{id:int}"
@using PetStore.Models
@inject PetStore.Data.PetStoreContext DbContext

<PageTitle>Thank You</PageTitle>

<h1>Thank You!</h1>

<!-- If no application is found, show an error message -->
@if (application is null)
{
  <p>We could not find your application.</p>
}
else
{
  <!-- Display user's name -->
  <p>Thank you, @application.FullName!</p>

  <!-- Confirmation message showing selected help type -->
  <p>
    We have successfully received your application to @application.HelpType?.ToLower().
    We will review your application and reach out to you within 7 to 10 business days.
  </p>

  <!-- Show additional details from the saved application -->
  <p><strong>Application ID:</strong> @application.Id</p>
  <p><strong>Submitted:</strong> @application.SubmittedAt.ToString("MMMM d, yyyy")</p>

  <!-- Navigation back to home page -->
  <NavLink href="/">Return to Home</NavLink>
}

@code {
  // Gets the application ID from the URL (e.g., /thankyou/5)
  [Parameter]
  public int Id { get; set; }

  // Stores the application retrieved from the database
  private ApplicationForm? application;

  /// Loads the application from the database when the page initializes
  protected override async Task OnInitializedAsync()
  {
    // Find the application using the ID passed in the URL
    application = await DbContext.ApplicationForms.FindAsync(Id);
  }
}